{
  // Launch configurations працюють у devcontainer і використовують GDB з image.
  // Для ДЗ 5 потрібно буде додати окрему конфігурацію за цим прикладом.
  "version": "0.2.0",
  "configurations": [
    {
      // Локальний debug стартера ДЗ 4. preLaunchTask збирає debug preset.
      "name": "Debug homework_04: ugv_odometry",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/homeworks/04_ugv_odometry/ugv_odometry",
      "args": [
        "${workspaceFolder}/homeworks/04_ugv_odometry/data/straight.txt"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: configure and build",
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Debug homework_05: telemetry_check",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/debug/homeworks/05_diagnostic_telemetry_parser/telemetry_check",
      "args": [
        "${workspaceFolder}/homeworks/05_diagnostic_telemetry_parser/data/good.txt"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: configure and build",
      "setupCommands": [
        {
          "description": "Увімкнути pretty-printing для STL типів у GDB.",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}